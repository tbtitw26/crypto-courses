# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.js

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
error.log

# local env files
.env
.env.local
.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# prisma
# /prisma/migrations - НЕ игнорируем, нужны для production деплоя

# generated files
/public/recipes/generated/*
!/public/recipes/generated/.gitkeep
/public/images/generated/*
!/public/images/generated/.gitkeep

# course generation
/logs/*
!/logs/.gitkeep
# course generation artifacts & migrated assets
/public/courses/
/public/images/courses/
/public/videos/
/public/media/
/public/courses/.generation-status.json
/public/courses/temp/*
!/public/courses/temp/.gitkeep
supabase-migration-map.*.json
/supabase-migration-report*.json
/logs/**/*.json
console.log
powershell.log

# tooling caches
.turbo
.vscode
.idea
*.tgz

# Legacy PHP files (removed during migration)
*.php
/vendor
/composer.json
/composer.lock
/libs
/templates
/content
/api/*.php
/assets/css
/assets/js

# Playwright
node_modules/
/test-results/
/playwright-report/
/blob-report/
/playwright/.cache/
/playwright/.auth/
