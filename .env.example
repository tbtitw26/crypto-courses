# Database (Prisma + PlanetScale / MySQL)
DATABASE_URL=mysql://user:password@localhost:3306/recipegenerator

# NextAuth
NEXTAUTH_SECRET=generate-with-openssl-rand-base64-32
NEXTAUTH_URL=http://localhost:3000

# Site metadata
SITE_BASE_URL=http://localhost:3000

# OpenAI (GPT-4o + DALL-E)
OPENAI_API_KEY=sk-your-openai-api-key

# SMTP (Nodemailer)
SMTP_HOST=mail.privateemail.com
SMTP_PORT=465
SMTP_USER=your-email@yourdomain.com
SMTP_PASS=your-email-password
SMTP_FROM=your-email@yourdomain.com
SMTP_FROM_NAME=Avenqor Support

# Supabase
# Supabase Storage (клиентский доступ к public bucket)
NEXT_PUBLIC_SUPABASE_URL=""
NEXT_PUBLIC_SUPABASE_ANON_KEY=""

# Supabase Storage (серверный доступ, только backend)
SUPABASE_URL=""
SUPABASE_SERVICE_ROLE_KEY=""

# Имена бакетов (чтобы не хардкодить в коде)
SUPABASE_BUCKET_COURSE_PDF="course-pdf"
SUPABASE_BUCKET_COURSE_IMAGES="course-images"
SUPABASE_BUCKET_COURSE_MEDIA="course-madia"